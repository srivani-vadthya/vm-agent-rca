{
  "ui_preferences": {
    "title": "RCA Chat Agent",
    "description": "AI-powered Root Cause Analysis for error logs and technical troubleshooting",
    "agent_icon": "🤖",
    "theme": {
      "primary_color": "#1a2332",
      "secondary_color": "#c9b99a",
      "accent_color": "#6b7c93",
      "background": "#f4f6f9"
    },
    "inputs": [
      {
        "name": "message",
        "label": "Ask me anything",
        "component_type": "textarea",
        "placeholder": "Paste an error log, describe a problem, or ask a question...",
        "default": "What can you help me with?",
        "required": true,
        "max_length": 10000,
        "help_text": "Enter an error log, exception, or technical question. The agent automatically detects the type and provides tailored analysis.",
        "examples": [
          "Error: Connection refused on localhost:9092",
          "What is a null pointer exception?",
          "How do I debug a memory leak in Java?",
          "Stack trace from failed deployment..."
        ]
      },
      {
        "name": "message_type",
        "label": "Message Type (Optional)",
        "component_type": "select",
        "placeholder": "Auto-detect",
        "options": [
          {
            "value": "greeting",
            "label": "Greeting"
          },
          {
            "value": "error_log",
            "label": "Error Log / Exception"
          },
          {
            "value": "simple_question",
            "label": "Simple Question"
          },
          {
            "value": "complex_question",
            "label": "Complex Question"
          },
          {
            "value": "general",
            "label": "General Query"
          }
        ],
        "default": null,
        "required": false,
        "help_text": "Leave blank to let the agent auto-detect. Specify a type to force a specific response style."
      }
    ],
    "outputs": {
      "data_mapping": [
        {
          "key": "response",
          "label": "Agent Response",
          "widget": "markdown",
          "description": "AI-generated response with structured analysis",
          "formatting": "markdown",
          "copy_button": true
        },
        {
          "key": "message_type",
          "label": "Detected Type",
          "widget": "badge",
          "description": "How the agent classified your message",
          "options": {
            "greeting": {
              "color": "blue",
              "icon": "👋"
            },
            "error_log": {
              "color": "red",
              "icon": "🔴"
            },
            "simple_question": {
              "color": "yellow",
              "icon": "❓"
            },
            "complex_question": {
              "color": "purple",
              "icon": "🎓"
            },
            "general": {
              "color": "gray",
              "icon": "💬"
            }
          }
        }
      ],
      "advanced_mapping": [
        {
          "key": "response",
          "label": "Full Response",
          "widget": "code",
          "language": "markdown",
          "visible_in": "developer_mode"
        }
      ]
    },
    "ui_sections": {
      "header": {
        "title": "RCA Chat Assistant",
        "subtitle": "Intelligent Root Cause Analysis & Troubleshooting",
        "icon": "🤖",
        "show_breadcrumb": true
      },
      "sidebar": {
        "show_chat_history": true,
        "show_settings": true,
        "collapsible": true,
        "features": [
          "Chat History",
          "Knowledge Base",
          "Settings"
        ]
      },
      "footer": {
        "show_usage_stats": true,
        "show_feedback": true,
        "powered_by_text": "Powered by Groq LLM + LangGraph"
      }
    },
    "interaction_config": {
      "loading_message": "Analyzing...",
      "error_message": "Failed to process request. Please try again.",
      "success_message": "Analysis complete!",
      "response_format": "markdown",
      "auto_scroll": true,
      "streaming": false,
      "conversation_mode": true
    },
    "features": {
      "chat_history": {
        "enabled": true,
        "max_sessions": 20,
        "auto_save": true
      },
      "knowledge_base": {
        "enabled": true,
        "supports_upload": true,
        "file_types": [".txt", ".log", ".md"],
        "max_file_size": "10MB"
      },
      "export": {
        "enabled": true,
        "formats": ["pdf", "markdown", "json"]
      },
      "share": {
        "enabled": false
      }
    },
    "behavioral_config": {
      "message_types": {
        "error_log": {
          "icon": "🔴",
          "color": "red",
          "response_style": "detailed",
          "includes": [
            "root_cause_analysis",
            "solution_steps",
            "prevention_tips"
          ]
        },
        "greeting": {
          "icon": "👋",
          "color": "blue",
          "response_style": "friendly",
          "max_length": 100
        },
        "simple_question": {
          "icon": "❓",
          "color": "yellow",
          "response_style": "concise",
          "max_length": 300
        },
        "complex_question": {
          "icon": "🎓",
          "color": "purple",
          "response_style": "comprehensive",
          "includes": [
            "detailed_explanation",
            "examples",
            "best_practices"
          ]
        },
        "general": {
          "icon": "💬",
          "color": "gray",
          "response_style": "conversational"
        }
      }
    },
    "accessibility": {
      "keyboard_shortcuts": {
        "send_message": "Ctrl+Enter",
        "clear_input": "Ctrl+L",
        "focus_input": "Ctrl+Shift+F"
      },
      "text_to_speech": false,
      "dark_mode": true,
      "high_contrast": true
    },
    "performance": {
      "debounce_delay_ms": 300,
      "max_history_items": 50,
      "response_timeout_ms": 60000,
      "cache_responses": true
    },
    "branding": {
      "agent_name": "RCA Chat Assistant",
      "agent_description": "Root Cause Analysis powered by AI",
      "logo_url": null,
      "welcome_message": "Hello! I'm your RCA Assistant. I can help analyze error logs, troubleshoot issues, or answer technical questions. What can I assist you with?",
      "footer_text": "Powered by Groq LLM & LangGraph Agent Framework"
    }
  },
  "marketplace_metadata": {
    "category": "Troubleshooting & Diagnostics",
    "subcategories": [
      "Error Analysis",
      "Log Analysis",
      "Root Cause Analysis",
      "Technical Support",
      "DevOps"
    ],
    "tags": [
      "error-analysis",
      "root-cause-analysis",
      "log-analysis",
      "troubleshooting",
      "devops",
      "agent",
      "langgraph",
      "rag",
      "knowledge-base"
    ],
    "use_cases": [
      "Analyze application error logs and stacktraces",
      "Diagnose system-level issues and connection failures",
      "Troubleshoot microservice communication problems",
      "Root cause hypothesis generation with validation",
      "Knowledge base Q&A for technical documentation",
      "Real-time error reporting and analysis"
    ],
    "target_users": [
      "DevOps Engineers",
      "SRE Engineers",
      "Backend Developers",
      "System Administrators",
      "Technical Support Teams",
      "Incident Response Teams"
    ],
    "pricing_tier": "free",
    "documentation_url": "https://github.com/yourusername/rca-agent#readme",
    "support_email": "support@yourdomain.com",
    "version": "1.0.0",
    "last_updated": "2026-06-08"
  }
}
